# Firebase Web (client) SDK config.
# Copy this file to `.env.local` and paste the values from the Firebase console:
#   Project settings (gear) → General → Your apps → Web app → SDK setup & config.
#
# These NEXT_PUBLIC_* keys are inlined into the client bundle and are SAFE to
# expose for the Firebase web SDK — access is controlled by Firestore Security
# Rules, not by key secrecy. (Restrict the key by HTTP referrer in the Google
# Cloud console for extra hygiene.)

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# GitHub webhooks (Tahap 3): NO global secret needed. Each project webhook gets
# its own secret, generated by the app and shown once when you create it under a
# project's "GitHub" dialog. Paste that per-webhook URL + secret into the repo's
# Settings → Webhooks (content type application/json, event: push).

# --- Firebase Admin SDK (server-only) — used by the GitHub webhook for secure writes.
# From Firebase console > Project settings > Service accounts > Generate new private key.
# Until all three are set, the webhook falls back to the client SDK.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----
"

# --- Document upload (Tahap 1) raw-file storage — OPTIONAL.
# Project briefs (pdf/docx) always have their TEXT extracted and saved to
# Firestore. Storing the original binary in Firebase Storage is best-effort and
# only happens when the Admin SDK (above) is set AND a bucket name is available.
# Defaults to NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET; override here if different.
# FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# --- GitHub App (server-only) — only needed to WRITE BACK to GitHub (commit status + comment).
# Not required for link+status. From your GitHub App settings.
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----
"

# autom8 task API token — used by scripts/autom8.mjs (and Claude) to update tasks.
AUTOM8_API_TOKEN=generate-a-long-random-string
# AUTOM8_BASE_URL=http://localhost:3000

# --- AI task generation (Tahap 2) — server-only.
# Anthropic API key used to draft tasks from an uploaded document via Claude.
# Until this is set, the "Generate tasks" button returns a friendly 503.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Daily Discord report (Tahap 4) — server-only.
# Incoming Webhook URL for the Aixel channel (Server Settings > Integrations >
# Webhooks). Until set, /api/reports/daily?dryRun=1 still previews the JSON.
DISCORD_WEBHOOK_URL=
# Protects /api/reports/daily. Vercel Cron sends this automatically as a Bearer
# token when set in the project's env. Manual triggers may use AUTOM8_API_TOKEN.
# The cron in vercel.json runs daily at 10:00 UTC (17:00 WIB).
CRON_SECRET=
