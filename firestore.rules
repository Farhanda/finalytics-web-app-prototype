rules_version = '2';

// ===========================================================================
// DEVELOPMENT RULES (current phase: no Firebase Auth)
// ===========================================================================
// Without Auth there is no `request.auth`, so rules cannot tell who the user is
// and therefore cannot enforce Admin/PM/Member access. Role visibility is
// enforced CLIENT-SIDE in src/lib/access.ts for now.
//
// These open rules match the Firestore "Test mode" you selected in the console.
// They are fine for a local prototype but MUST be locked down before any real
// or public deployment — anyone with the project config could read/write.
//
// To deploy these: Firestore console → Rules → paste → Publish
// (or `firebase deploy --only firestore:rules` with the Firebase CLI).

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true; // DEV ONLY — replace once Auth is added.
    }
  }
}

